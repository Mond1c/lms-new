{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run:*)",
      "Bash(go mod tidy:*)",
      "Bash(go mod download:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(buf lint:*)",
      "Bash(buf build:*)",
      "Bash(buf generate:*)",
      "Bash(buf breaking:*)",
      "Bash(sqlc generate:*)",
      "Bash(sqlc vet:*)",
      "Bash(golangci-lint run:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(grpcurl:*)",
      "Bash(curl -fsS http://localhost:*)"
    ],
    "ask": [
      "Bash(make up:*)",
      "Bash(make down:*)",
      "Bash(make nuke:*)",
      "Bash(make clean-all:*)",
      "Bash(docker compose:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)"
    ]
  }
}
